# TrendForge AI - Backend configuration
# Copy this file to .env and fill in values.

# API server
TRENDFORGE_HOST=127.0.0.1
TRENDFORGE_PORT=8756

# Comma-separated list of allowed frontend origins
TRENDFORGE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,tauri://localhost

# SQLite database file (relative to backend/ or absolute)
TRENDFORGE_DATABASE_URL=sqlite:///./trendforge.db

# Google Gemini API key (enables the AI intelligence engine)
TRENDFORGE_GEMINI_API_KEY=
# Gemini model to use
TRENDFORGE_GEMINI_MODEL=gemini-2.5-flash

# UX / behavior
TRENDFORGE_THEME=dark
TRENDFORGE_NOTIFICATIONS=true
TRENDFORGE_AUTO_BACKUP=false
TRENDFORGE_DEVELOPER_MODE=false
# Optional URL returning {"version": "x.y.z"} for update checks
TRENDFORGE_UPDATE_URL=

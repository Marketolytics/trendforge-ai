# TrendForge AI - backend configuration
# Copy to .env and fill in values. Never commit your real .env.

# ---------------------------------------------------------------------------
# Environment: "development" (default) or "production".
# In production, HSTS is sent and errors are terse.
APP_ENV=development

# Secret used to sign tokens/sessions (reserved for future auth).
# Generate one, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# ---------------------------------------------------------------------------
# Database
# Development (default): local SQLite under the workspace (leave DATABASE_URL blank).
# Production (Hostinger MySQL): a full SQLAlchemy URL. Example:
#   DATABASE_URL=mysql+pymysql://u123_user:password@localhost:3306/u123_trendforge?charset=utf8mb4
DATABASE_URL=

# ---------------------------------------------------------------------------
# AI provider (Google Gemini). Store the key here in production — the app reads
# it from the environment (no OS credential store on shared hosting).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ---------------------------------------------------------------------------
# CORS: comma-separated origins allowed to call the API. When the frontend is
# served from the same domain as the API this can be left as-is.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---------------------------------------------------------------------------
# Filesystem layout. On Hostinger point these at a writable location, e.g.
# /home/uXXXXXXXX/trendforge-data. Leave blank to use backend/data.
DATA_DIR=
CACHE_DIRECTORY=
EXPORT_DIRECTORY=
LOG_DIRECTORY=

# Path to the built React app (index.html + assets/). Leave blank to use
# ../frontend/dist. Set this to co-host the UI from the API.
FRONTEND_DIST=

# ---------------------------------------------------------------------------
# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# API server bind (used by uvicorn / run_server.py; Passenger manages this in
# production so these are ignored there).
TRENDFORGE_HOST=127.0.0.1
TRENDFORGE_PORT=8000

# Optional URL returning {"version": "x.y.z"} for update checks.
TRENDFORGE_UPDATE_URL=

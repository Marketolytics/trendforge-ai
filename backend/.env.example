# TrendForge AI - Backend configuration
# Copy this file to .env and fill in values.

# API server
TRENDFORGE_HOST=127.0.0.1
TRENDFORGE_PORT=8756

# Comma-separated list of allowed frontend origins
TRENDFORGE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,tauri://localhost

# SQLite database file (relative to backend/ or absolute)
TRENDFORGE_DATABASE_URL=sqlite:///./trendforge.db

# Google Gemini API key (used in later milestones)
GEMINI_API_KEY=

# Frontend production build configuration.
# Copy to .env.production before running `npm run build`.

# API base URL. Leave blank when the API is served from the SAME origin as the
# frontend (recommended — the backend co-hosts the built app). Set an absolute
# URL only if the API lives on a different domain, e.g. https://api.example.com
VITE_API_BASE_URL=

# Public base path. Use "/" when served at the domain root (default), or a
# subpath like "/app/" when deployed under a subdirectory.
VITE_BASE=/

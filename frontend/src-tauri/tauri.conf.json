{
  "productName": "TrendForge AI",
  "version": "1.0.0",
  "identifier": "com.trendforge.ai",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TrendForge AI",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "center": true,
        "decorations": true,
        "theme": "Dark",
        "backgroundColor": "#1a1a1f"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "externalBin": ["binaries/trendforge-backend"],
    "publisher": "TrendForge",
    "copyright": "© 2026 TrendForge",
    "category": "Productivity",
    "shortDescription": "AI content intelligence desktop app",
    "longDescription": "TrendForge AI collects trending topics, researches them across sources, and generates production-ready content packages — locally on your machine.",
    "licenseFile": "installer/license.txt",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": false,
        "installerHooks": "installer/hooks.nsh",
        "installerIcon": "icons/icon.ico",
        "shortcutName": "TrendForge AI"
      }
    }
  }
}

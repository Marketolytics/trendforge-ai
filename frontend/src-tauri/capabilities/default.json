{
  "identifier": "default",
  "description": "Default capabilities for the main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "shell:allow-execute",
    {
      "identifier": "shell:allow-spawn",
      "allow": [{ "name": "binaries/trendforge-backend", "sidecar": true, "args": true }]
    }
  ]
}
